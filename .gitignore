# ==============================================================================
# universal-code-merger — .gitignore
# ==============================================================================


# ------------------------------------------------------------------------------
# UCM runtime outputs — never commit generated files
# ------------------------------------------------------------------------------
outputs/
logs/


# ------------------------------------------------------------------------------
# UCM personal config — commit .env.example, NOT .env
# ------------------------------------------------------------------------------
configs/base/.env
configs/archive


# ------------------------------------------------------------------------------
# Python — bytecode & cache
# ------------------------------------------------------------------------------
__pycache__/
*.py[codz]
*$py.class
*.pyo
*.pyd
*.so


# ------------------------------------------------------------------------------
# Python — packaging & distribution
# ------------------------------------------------------------------------------
build/
dist/
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.manifest
*.spec


# ------------------------------------------------------------------------------
# Python — virtual environments
# ------------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
__pypackages__/
.pixi/


# ------------------------------------------------------------------------------
# Python — testing & coverage
# ------------------------------------------------------------------------------
.tox/
.nox/
.coverage
.coverage.*
.cache
htmlcov/
coverage.xml
*.cover
*.py.cover
nosetests.xml
.hypothesis/
.pytest_cache/
cover/


# ------------------------------------------------------------------------------
# Python — type checkers & linters
# ------------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/
cython_debug/


# ------------------------------------------------------------------------------
# Python — package managers
# ------------------------------------------------------------------------------
.pdm-python
.pdm-build/
pip-log.txt
pip-delete-this-directory.txt
# Uncomment to ignore lock files:
# Pipfile.lock
# uv.lock
# poetry.lock
# pixi.lock


# ------------------------------------------------------------------------------
# Python — misc tools
# ------------------------------------------------------------------------------
.spyderproject
.spyproject
.ropeproject
.abstra/
profile_default/
ipython_config.py
.ipynb_checkpoints
*.sage.py
*.mo
*.pot
*.log
.pypirc


# ------------------------------------------------------------------------------
# IDE & editors
# ------------------------------------------------------------------------------
.idea/
.vscode/
.cursorignore
.cursorindexingignore


# ------------------------------------------------------------------------------
# Documentation builds
# ------------------------------------------------------------------------------
docs/_build/
/site
target/


# ------------------------------------------------------------------------------
# OS generated files
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
