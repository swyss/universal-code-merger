{
  "_comment": "Global defaults — overridden by profile.json > .env > CLI",
  "output_dir": "outputs",
  "log_dir": "logs",
  "encoding": "utf-8",
  "timestamp_format": "%Y-%m-%d_%H-%M-%S",
  "max_file_size_kb": 500,
  "max_depth": null,
  "dry_run": false,
  "warn_on_secrets": true,
  "whitelist_ext": [
    ".py", ".ts", ".js", ".vue",
    ".json", ".toml", ".yml", ".yaml",
    ".xml", ".html", ".css",
    ".md", ".txt", ".env", ".config"
  ],
  "blacklist_dirs": [
    "node_modules", "__pycache__", ".git", ".idea",
    ".venv", "venv", "dist", "build", "outputs", "logs"
  ],
  "blacklist_files": [],
  "blacklist_patterns": []
}
